{
  "baseBranches": [
    "main"
  ],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate: Update Istio CNI Package Dependencies",
  "draftPR": true,
  "labels": [
    "istio-cni",
    "Big Bang Core",
    "Package Sustainment",
    "kind::maintenance",
    "renovate"
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "docker",
        "helm"
      ],
      "matchManagers": [
        "custom.regex",
        "helmv3"
      ],
      "groupName": "Istio CNI",
      "postUpgradeTasks": {
        "commands": [
          "match-chart-yaml-appversion",
          "bump-changelog '{{#each upgrades}}- {{depName}} {{currentVersion}} -> {{newVersion}}\\n{{/each}}'",
          "regenerate-helm-docs"
        ],
        "fileFilters": [
          "chart/Chart.yaml",
          "README.md",
          "CHANGELOG.md"
        ],
        "executionMode": "branch"
      }
    }
  ],
  "separateMajorMinor": false,
  "postUpdateOptions": [
    "helmUpdateSubChartArchives"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^chart/Chart\\.yaml$/"
      ],
      "matchStrings": [
        "- Istio:\\s*(?<currentValue>.+)",
        "appVersion:[^\\S\\r\\n]+(?<currentValue>.+)"
      ],
      "depNameTemplate": "cni",
      "datasourceTemplate": "helm",
      "registryUrlTemplate": "https://istio-release.storage.googleapis.com/charts"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^chart/Chart\\.yaml$/"
      ],
      "matchStrings": [
        "image:[^\\S\\r\\n]+(?<depName>.+):(?<currentValue>.+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Update tag in values to match upstream",
      "managerFilePatterns": [
        "/^chart/values.yaml$/"
      ],
      "matchStrings": [
        "tag:\\s+(?<currentValue>.+)"
      ],
      "autoReplaceStringTemplate": "tag: {{newValue}}",
      "depNameTemplate": "cni",
      "datasourceTemplate": "helm",
      "registryUrlTemplate": "https://istio-release.storage.googleapis.com/charts"
    }
  ]
}
